<Window x:Class="CyberBotGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CyberBotGUI"
        mc:Ignorable="d"
        Title="CyberBot - Spreading Cyber Security Awareness"
        Height="700" Width="500" MinHeight="500" MinWidth="400"
        Background="#0D1117"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="SendButton" TargetType="Button">
            <Setter Property="Background" Value="#00FF41"/>
            <Setter Property="Foreground" Value="#0D1117"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="20" Padding="16,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#00CC34"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>

            </Setter>
        </Style>

        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="Foreground" Value="#F0F6FC"/>
            <Setter Property="CaretBrush" Value="#00FF41"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>
        
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/> <!--Header section of app-->
            <RowDefinition Height="*"/>  <!--Chat area for chat-->
            <RowDefinition Height="70"/> <!--Input texr bar-->
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#161B22" BorderBrush="#30363D" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                <Ellipse Width="12" Height="12" Fill="#00FF41" Margin="0,0,10,0"/>
                <TextBlock Text="CyberBot" 
                           Foreground="#00FF41"
                           FontSize="16"
                           FontFamily="Consolas"/>
                <TextBlock Text="CyberSecurity Awareness Assistant"
                           Foreground="#8B949E"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="4,0,0,0"/>
            </StackPanel>
        </Border>

        <ScrollViewer x:Name="ChatScroll" Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="12,8">
            <StackPanel x:Name="ChatPanel"
                        Orientation="Vertical"/>
        </ScrollViewer>

        <Border Grid.Row="2" Background="#161B22"
                BorderBrush="#30363D"
                BorderThickness="0, 1, 0, 0"
                Padding="12, 10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="InputBox" Grid.Column="0"
                         Style="{StaticResource InputBox}"
                         Height="42"
                         Margin="0,0, 8, 0"
                         KeyDown="InputBox_KeyDown"
                         TextChanged="InputBox_TextChange"/>

                <Button x:Name="SendButton" Grid.Column="1"
                        Style="{StaticResource SendButton}"
                        Height="42" Width="80"
                        Content="Send"
                        Click="SendButton_Click"
                        IsEnabled="False"/>
            </Grid>
        </Border>

    </Grid>
</Window>
