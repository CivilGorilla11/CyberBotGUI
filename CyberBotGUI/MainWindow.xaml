<Window x:Class="CyberBotGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CyberBotGUI"
        mc:Ignorable="d"
        Title="CyberBot - Spreading Cyber Security Awareness"
        Height="700" Width="500" MinHeight="500" MinWidth="400"
        Background="#0D1117"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="SendButton" TargetType="Button">
            <Setter Property="Background" Value="#00FF41"/>
            <Setter Property="Foreground" Value="#0D1117"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="20" Padding="16,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#00CC34"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>

            </Setter>
        </Style>

        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="Foreground" Value="#F0F6FC"/>
            <Setter Property="CaretBrush" Value="#00FF41"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>

        <!-- ============================= -->
        <!-- ALIEN NEON LOCK BACKGROUND -->
        <!-- ============================= -->

        <Grid IsHitTestVisible="False">

            <!-- Dark background -->
            <Rectangle Fill="#050816"/>

            <!-- Radial neon glow -->
            <Ellipse Width="700"
                     Height="700"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Opacity="0.18">

                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#00FFD5" Offset="0"/>
                        <GradientStop Color="#050816" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- Alien lock hologram -->
            <TextBlock Text="⌬"
                       FontSize="320"
                       FontWeight="Bold"
                       Foreground="#00FFD5"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Opacity="0.08">

                <TextBlock.Effect>
                    <DropShadowEffect BlurRadius="50"
                                      Color="#00FFD5"
                                      ShadowDepth="0"
                                      Opacity="1"/>
                </TextBlock.Effect>

            </TextBlock>

            <!-- Animated neon line -->
            <Canvas>

                <Rectangle Width="2"
                           Height="1200"
                           Fill="#00FFD5"
                           Opacity="0.12"
                           Canvas.Left="250">

                    <Rectangle.RenderTransform>
                        <TranslateTransform x:Name="LineMove1"/>
                    </Rectangle.RenderTransform>

                    <Rectangle.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever"
                                            AutoReverse="True">

                                    <DoubleAnimation
                                        Storyboard.TargetName="LineMove1"
                                        Storyboard.TargetProperty="X"
                                        From="-60"
                                        To="60"
                                        Duration="0:0:5"/>

                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Rectangle.Triggers>

                </Rectangle>

            </Canvas>

        </Grid>


        <!-- ============================= -->
        <!-- MAIN CHAT UI -->
        <!-- ============================= -->

        <Grid Panel.ZIndex="1">

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>


            <!-- CHAT AREA -->
            <ScrollViewer x:Name="ChatScroll"
                          Grid.Row="0"
                          VerticalScrollBarVisibility="Hidden"
                          Margin="20">

                <StackPanel x:Name="ChatPanel"/>

            </ScrollViewer>


            <!-- INPUT AREA -->
            <Border Grid.Row="1"
                    Margin="20"
                    CornerRadius="20"
                    Background="#11000000"
                    BorderBrush="#2200FFD5"
                    BorderThickness="1"
                    Padding="10">

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>


                    <!-- MESSAGE INPUT -->
                    <TextBox x:Name="InputBox"
                             Grid.Column="0"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="White"
                             FontSize="15"
                             CaretBrush="#00FFD5"
                             VerticalContentAlignment="Center"
                             KeyDown="InputBox_KeyDown"
                             TextChanged="InputBox_TextChange"/>


                    <!-- SEND BUTTON -->
                    <Button x:Name="SendButton" 
                            Grid.Column="1"
                            Width="60"
                            Height="40"
                            Margin="10,0,0,0"
                            Content="➤"
                            Click="SendButton_Click"
                            Background="#001A1A"
                            Foreground="#00FFD5"
                            BorderBrush="#00FFD5"
                            BorderThickness="1"
                            FontSize="18"
                            Cursor="Hand">

                        <Button.Effect>
                            <DropShadowEffect BlurRadius="20"
                                              ShadowDepth="0"
                                              Color="#00FFD5"
                                              Opacity="0.7"/>
                        </Button.Effect>

                    </Button>

                </Grid>

            </Border>

        </Grid>

    </Grid>

</Window>
